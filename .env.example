# Database (Supabase PostgreSQL)
# Connect to Supabase via connection pooling
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true
# Direct connection to the database. Used for migrations
DIRECT_URL=postgresql://postgres.YOUR_PROJECT:YOUR_PASSWORD@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Auth
# NextAuthが使用するアプリのベースURL
NEXTAUTH_URL=http://localhost:3000
# JWTトークンの署名に使用するシークレットキー
NEXTAUTH_SECRET=your-nextauth-secret
# パスワードハッシュに付加するペッパー値
PASSWORD_PEPPER=your-password-pepper

# TMDB
# TMDB APIのアクセストークン
TMDB_ACCESS_TOKEN=your-tmdb-access-token

# Supabase
# Supabase Storageを画像保存に使用するかどうか
NEXT_PUBLIC_USE_SUPABASE_STORAGE=true
# SupabaseプロジェクトのURL
NEXT_PUBLIC_SUPABASE_PROJECT_URL=https://YOUR_PROJECT.supabase.co
# Supabaseの公開APIキー
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# 画像を保存するSupabase Storageのバケット名
SUPABASE_STORAGE_BUCKET=your-bucket-name

# seed(ダミーデータ)のパスワード
SEED_PASSWORD=password
