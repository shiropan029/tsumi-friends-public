# Database (Supabase PostgreSQL)
# アプリからのDB接続に使用
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1
# prisma migrateで使用
DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Auth
# NextAuthが使用するアプリのベースURL
NEXTAUTH_URL=http://localhost:3000
# JWTトークンの署名に使用するシークレットキー
NEXTAUTH_SECRET=your-nextauth-secret
# パスワードハッシュに付加するペッパー値
PASSWORD_PEPPER=your-password-pepper

# TMDB
# TMDB APIのアクセストークン
TMDB_ACCESS_TOKEN=your-tmdb-access-token

# Supabase
# Supabase Storageを画像保存に使用するかどうか
NEXT_PUBLIC_USE_SUPABASE_STORAGE=true
# SupabaseプロジェクトのURL
NEXT_PUBLIC_SUPABASE_PROJECT_URL=https://YOUR_PROJECT.supabase.co
# Supabaseの公開APIキー
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key
# 画像を保存するSupabase Storageのバケット名
SUPABASE_STORAGE_BUCKET=your-bucket-name

# seed(ダミーデータ)のパスワード
SEED_PASSWORD=password
